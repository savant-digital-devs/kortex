generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── ENUMS ───────────────────────────────────────────────

enum Plan {
  STANDARD
  AUTONOMOUS
  ENTERPRISE
}

enum ProjectType {
  SOFTWARE
  SUPPORT
  TIMELINE
}

enum MemberRole {
  OWNER
  ADMIN
  MANAGER
  EMPLOYEE
}

// ─── ORGANIZAÇÃO (TENANT) ────────────────────────────────

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(STANDARD)
  seats     Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  Member[]
  projects Project[]
}

// ─── USUÁRIO ─────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  members      Member[]
  timeSessions TimeSession[]
  auditLogs    AuditLog[]
}

// ─── MEMBRO (USER + ORGANIZATION) ────────────────────────

model Member {
  id             String     @id @default(uuid())
  role           MemberRole @default(EMPLOYEE)
  permissions    Int        @default(0) // bitmask: CREATE=1, EDIT=2, DELETE=4
  createdAt      DateTime   @default(now())

  userId         String
  organizationId String

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks        Task[]

  @@unique([userId, organizationId])
}

// ─── PROJETO ─────────────────────────────────────────────

model Project {
  id              String      @id @default(uuid())
  name            String
  description     String?
  type            ProjectType @default(SOFTWARE)
  githubRepoUrl   String?
  githubRepoId    String?
  publicToken     String?     @unique
  publicTokenExpiresAt DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  columns  Column[]
  auditLogs AuditLog[]
}

// ─── COLUNA (KANBAN) ─────────────────────────────────────

model Column {
  id        String   @id @default(uuid())
  name      String
  order     Int
  createdAt DateTime @default(now())

  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  tasks Task[]
}

// ─── TASK ────────────────────────────────────────────────

model Task {
  id          String    @id @default(uuid())
  title       String
  description String?
  priority    Int       @default(0)
  order       Int       @default(0)
  dueDate     DateTime?
  deletedAt   DateTime? // soft delete
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  columnId   String
  assigneeId String?

  column   Column  @relation(fields: [columnId], references: [id], onDelete: Cascade)
  assignee Member? @relation(fields: [assigneeId], references: [id], onDelete: SetNull)

  timeSessions TimeSession[]
  auditLogs    AuditLog[]
}

// ─── TIME TRACKING ────────────────────────────────────────

model TimeSession {
  id        String    @id @default(uuid())
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  source    String    @default("manual") // manual | github_commit | github_pr

  taskId String
  userId String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── AUDIT LOG ────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(uuid())
  action     String
  oldState   Json?
  newState   Json?
  createdAt  DateTime @default(now())

  actorId    String
  resourceId String
  projectId  String?
  taskId     String?

  actor   User     @relation(fields: [actorId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
}